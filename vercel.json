{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/audio.mp3",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    },
    {
      "source": "/trailer.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    }
  ],
  "rewrites": [],
  "functions": {
    "api/subscribe.js": {
      "maxDuration": 10
    }
  }
}
